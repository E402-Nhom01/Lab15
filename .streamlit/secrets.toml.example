# Streamlit Cloud → Settings → Secrets: paste these (without the .example suffix).
# For local dev, copy this file to .streamlit/secrets.toml and fill in values.
# DO NOT commit the real secrets.toml.

OPENAI_API_KEY = "sk-..."

# Optional: gate the app behind a shared password. Leave unset for open access.
APP_PASSWORD = "change-me"

# Optional: override per-session query cap (default 20).
# MAX_QUERIES_PER_SESSION = "20"

# Optional: cost estimate for the dashboard ($/1K tokens).
# COST_PER_1K_TOKENS = "0.002"
